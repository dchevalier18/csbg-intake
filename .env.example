# Copy to .env (Docker) or .env.local (npm run dev).

# ---- database ----------------------------------------------------------
# postgres://…       PostgreSQL (production)
# pglite://<dir>     embedded database, zero setup (local/offline mode)
# pglite://memory    embedded, in-memory (throwaway)
# Unset => postgres://csbg:csbg@localhost:5432/csbg_intake
DATABASE_URL=postgres://csbg:csbg@localhost:5432/csbg_intake

# ---- docker compose ----------------------------------------------------
# Domain Caddy should obtain certificates for (localhost = plain-HTTP trial)
CSBG_DOMAIN=localhost
# Password for the bundled PostgreSQL container
DB_PASSWORD=change-me

# ---- escape hatches ----------------------------------------------------
# LAN-only staging without TLS (disables the Secure cookie flag + HSTS).
# NEVER set this on anything reachable from the internet.
# CSBG_ALLOW_HTTP=1
