# Copy to .env.local for local development.
#
# The app reads DATABASE_URL at startup. On the staging server this is set in
# /etc/csbg-intake.env and points at the server's own localhost Postgres.
#
# For local development you need a Postgres reachable from this machine:
#   - a local Postgres / Docker container, e.g.
#       DATABASE_URL=postgres://csbg:csbg@localhost:5432/csbg_intake
#   - or the staging DB once LAN access is enabled on the server (see deploy/README.md):
#       DATABASE_URL=postgres://csbg:CHANGE_ME@YOUR_SERVER_IP:5432/csbg_intake
#
# No DATABASE_URL set => defaults to postgres://csbg:csbg@localhost:5432/csbg_intake
# (`npm run smoke` needs no database — it runs the schema against in-process PGlite.)
DATABASE_URL=postgres://csbg:csbg@localhost:5432/csbg_intake
